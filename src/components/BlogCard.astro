---
interface Props {
  slug: string;
  title: string;
  description: string;
  coverUrl: string;
  publishDate: Date;
  author: string;
  tags: string[];
}

const { slug, title, description, coverUrl, publishDate, author, tags } = Astro.props;

const formattedDate = publishDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<article class="group overflow-hidden rounded-2xl border border-outline bg-surface-card transition-all hover:border-primary/50 hover:shadow-2xl hover:shadow-primary/10">
  <a href={`/blog/${slug}/`} class="block">
    <div class="relative aspect-[16/9] overflow-hidden">
      <img
        src={coverUrl}
        alt={title}
        class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
        loading="lazy"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-black/40 via-transparent to-transparent"></div>
    </div>

    <div class="p-6">
      <div class="flex flex-wrap gap-2 mb-3">
        {tags.map((tag) => (
          <span class="rounded-full bg-chip-bg px-2.5 py-0.5 text-xs font-medium text-chip-text">
            {tag}
          </span>
        ))}
      </div>

      <h3 class="text-xl font-bold text-on-surface-heading group-hover:text-primary transition-colors">
        {title}
      </h3>

      <p class="mt-2 text-sm leading-relaxed text-on-surface-muted line-clamp-3">
        {description}
      </p>

      <div class="mt-4 flex items-center justify-between text-xs text-on-surface-muted">
        <span>{author}</span>
        <time datetime={publishDate.toISOString()}>{formattedDate}</time>
      </div>
    </div>
  </a>
</article>
