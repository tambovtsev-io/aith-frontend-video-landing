          <ul class="space-y-3 text-on-surface-muted">
            <li><a href="#" class="hover:text-primary transition-colors">Brand Films</a></li>
            <li><a href="#" class="hover:text-primary transition-colors">Commercials</a></li>
            <li><a href="#" class="hover:text-primary transition-colors">Documentary</a></li>
            <li><a href="#" class="hover:text-primary transition-colors">Music Videos</a></li>
            <li><a href="#" class="hover:text-primary transition-colors">Event Coverage</a></li>
          </ul>
        </div>
        <div>
          <h3 class="font-semibold text-on-surface-heading mb-4">Company</h3>
          <ul class="space-y-3 text-on-surface-muted">
            <li><a href="/portfolio/" class="hover:text-primary transition-colors">Portfolio</a></li>
            <li><a href="/blog/" class="hover:text-primary transition-colors">Blog</a></li>
            <li><a href="#" class="hover:text-primary transition-colors">About Us</a></li>
            <li><a href="#" class="hover:text-primary transition-colors">Careers</a></li>
            <li><a href="/#contact" class="hover:text-primary transition-colors">Contact</a></li>
          </ul>
        </div>
      </div>
    </div>

    <div class="mt-12 border-t border-outline pt-8 text-center text-sm text-on-surface-muted">
      &copy; {new Date().getFullYear()} Luminary Films. All rights reserved.
    </div>
  </div>
