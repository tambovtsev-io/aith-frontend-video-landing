---
---

<section id="contact" class="relative py-24 lg:py-32">
  <div class="pointer-events-none absolute left-0 top-0 h-px w-full bg-gradient-to-r from-transparent via-outline to-transparent"></div>

  <div class="pointer-events-none absolute inset-0 bg-gradient-to-b from-transparent via-grad-from/5 to-transparent"></div>

  <div class="relative mx-auto max-w-7xl px-6">
    <div class="text-center">
      <span class="inline-block rounded-full bg-chip-bg px-3 py-1 text-xs font-semibold uppercase tracking-wider text-chip-text">
        Contact
      </span>
      <h2 class="mt-4 text-4xl font-extrabold tracking-tight text-on-surface-heading sm:text-5xl">
        Let's work together
      </h2>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-on-surface-muted">
        Have a project in mind? Reach out — we'd love to hear your story and figure out the best way to tell it.
      </p>
    </div>

    <div class="mx-auto mt-16 grid max-w-4xl gap-6 sm:grid-cols-2">
      <!-- Email -->
      <a
        href="mailto:hello@luminaryfilms.co"
        class="group flex items-start gap-5 rounded-2xl border border-outline bg-surface-card p-6 transition-all hover:border-primary/50 hover:shadow-2xl hover:shadow-primary/10"
      >
        <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-gradient-to-br from-grad-from to-grad-via text-white shadow-lg shadow-primary/20">
          <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
          </svg>
        </div>
        <div>
          <h3 class="text-lg font-bold text-on-surface-heading group-hover:text-primary transition-colors">
            Email Us
          </h3>
          <p class="mt-1 text-sm text-on-surface-muted">
            For project inquiries and general questions
          </p>
          <span class="mt-3 inline-flex items-center gap-1.5 text-sm font-semibold text-primary">
            hello@luminaryfilms.co
            <svg class="h-4 w-4 transition-transform group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
            </svg>
          </span>
        </div>
      </a>

      <!-- Telegram -->
      <a
        href="https://t.me/luminaryfilms"
        target="_blank"
        rel="noopener noreferrer"
        class="group flex items-start gap-5 rounded-2xl border border-outline bg-surface-card p-6 transition-all hover:border-primary/50 hover:shadow-2xl hover:shadow-primary/10"
      >
        <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-gradient-to-br from-grad-via to-grad-to text-white shadow-lg shadow-primary/20">
          <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24">
            <path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.479.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/>
          </svg>
        </div>
        <div>
          <h3 class="text-lg font-bold text-on-surface-heading group-hover:text-primary transition-colors">
            Telegram
          </h3>
          <p class="mt-1 text-sm text-on-surface-muted">
            Quick chats and fast responses
          </p>
          <span class="mt-3 inline-flex items-center gap-1.5 text-sm font-semibold text-primary">
            @luminaryfilms
            <svg class="h-4 w-4 transition-transform group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
            </svg>
          </span>
        </div>
      </a>
    </div>
  </div>
</section>
