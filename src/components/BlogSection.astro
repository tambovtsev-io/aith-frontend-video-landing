---
import { getCollection } from 'astro:content';
import BlogCard from './BlogCard.astro';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime()
);
---

<section id="blog" class="relative py-24 lg:py-32">
  <div class="pointer-events-none absolute left-0 top-0 h-px w-full bg-gradient-to-r from-transparent via-outline to-transparent"></div>

  <div class="mx-auto max-w-7xl px-6">
    <div class="text-center">
      <span class="inline-block rounded-full bg-chip-bg px-3 py-1 text-xs font-semibold uppercase tracking-wider text-chip-text">
        Blog
      </span>
      <h2 class="mt-4 text-4xl font-extrabold tracking-tight text-on-surface-heading sm:text-5xl">
        From the journal
      </h2>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-on-surface-muted">
        Tips, breakdowns, and behind-the-scenes insights from our production team.
      </p>
    </div>

    <div class="mt-16 grid gap-8 md:grid-cols-2">
      {posts.map((post) => (
        <BlogCard
          slug={post.id}
          title={post.data.title}
          description={post.data.description}
          coverUrl={post.data.coverUrl}
          publishDate={post.data.publishDate}
          author={post.data.author}
          tags={post.data.tags}
        />
      ))}
    </div>

    <div class="mt-12 text-center">
      <a
        href="/blog/"
        class="inline-flex items-center gap-2 rounded-full border border-outline bg-surface-card px-7 py-3 text-sm font-semibold text-on-surface-heading hover:border-primary hover:text-primary transition-colors"
      >
        View All Posts
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
        </svg>
      </a>
    </div>
  </div>
</section>
