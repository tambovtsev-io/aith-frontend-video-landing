---
---

<section class="relative flex min-h-screen items-center justify-center overflow-hidden pt-20">
  <div class="absolute inset-0 bg-gradient-to-br from-grad-from/10 via-transparent to-grad-to/10"></div>

  <div class="pointer-events-none absolute -top-40 left-1/2 h-[600px] w-[600px] -translate-x-1/2 rounded-full bg-gradient-to-br from-grad-from/20 via-grad-via/10 to-transparent blur-3xl"></div>
  <div class="pointer-events-none absolute -bottom-40 right-0 h-[400px] w-[400px] rounded-full bg-gradient-to-tl from-grad-to/20 via-grad-via/10 to-transparent blur-3xl"></div>

  <div class="relative z-10 mx-auto max-w-5xl px-6 text-center">
    <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-outline bg-surface-card/50 px-4 py-1.5 text-sm font-medium text-on-surface-muted backdrop-blur-sm">
      <span class="inline-block h-2 w-2 rounded-full bg-gradient-to-r from-grad-from to-grad-via animate-pulse"></span>
      Now booking for Q3 2026
    </div>

    <h1 class="text-5xl font-extrabold leading-tight tracking-tight text-on-surface-heading sm:text-6xl lg:text-7xl">
      Cinematic stories<br />
      <span class="bg-gradient-to-r from-grad-from via-grad-via to-grad-to bg-clip-text text-transparent">
        that move audiences
      </span>
    </h1>

    <p class="mx-auto mt-6 max-w-2xl text-lg leading-relaxed text-on-surface-muted sm:text-xl">
      Luminary Films is an award-winning video production agency crafting brand films,
      commercials, and documentary content for companies that refuse to blend in.
    </p>

    <div class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row">
      <a href="#work" class="inline-flex items-center gap-2 rounded-full bg-gradient-to-r from-grad-from via-grad-via to-grad-to px-8 py-3.5 text-base font-semibold text-white shadow-xl shadow-primary/25 hover:shadow-primary/40 transition-all hover:scale-105">
        View Our Work
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" /></svg>
      </a>
      <a href="#contact" class="inline-flex items-center gap-2 rounded-full border border-outline bg-surface-card px-8 py-3.5 text-base font-semibold text-on-surface-heading hover:border-primary hover:text-primary transition-colors">
        Contact us
      </a>
    </div>

    <div class="mx-auto mt-20 grid max-w-3xl grid-cols-2 gap-8 text-center">
      <div>
        <div class="text-3xl font-extrabold text-on-surface-heading">150+</div>
        <div class="mt-1 text-sm text-on-surface-muted">Projects delivered</div>
      </div>
      <div>
        <div class="text-3xl font-extrabold text-on-surface-heading">5</div>
        <div class="mt-1 text-sm text-on-surface-muted">Years of craft</div>
      </div>
    </div>
  </div>
</section>
