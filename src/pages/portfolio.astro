---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import CaseCard from '../components/CaseCard.astro';

const cases = (await getCollection('cases')).sort((a, b) => a.data.order - b.data.order);
---

<Layout title="Portfolio — Luminary Films" description="Browse our complete portfolio of brand films, commercials, documentaries, and more.">
  <section class="pt-28 pb-24">
    <div class="mx-auto max-w-7xl px-6">
      <div class="text-center">
        <span class="inline-block rounded-full bg-chip-bg px-3 py-1 text-xs font-semibold uppercase tracking-wider text-chip-text">
          Portfolio
        </span>
        <h1 class="mt-4 text-4xl font-extrabold tracking-tight text-on-surface-heading sm:text-5xl">
          All projects
        </h1>
        <p class="mx-auto mt-4 max-w-2xl text-lg text-on-surface-muted">
          Every story we've helped bring to life — from high-energy brand campaigns to intimate documentary portraits.
        </p>
      </div>

      <div class="mt-16 grid gap-8 md:grid-cols-2 lg:grid-cols-3">
        {cases.map((c) => (
          <CaseCard
            slug={c.id}
            title={c.data.title}
            tagline={c.data.tagline}
            videoUrl={c.data.videoUrl}
            posterUrl={c.data.posterUrl}
            tags={c.data.tags}
          />
        ))}
      </div>
    </div>
  </section>
</Layout>
